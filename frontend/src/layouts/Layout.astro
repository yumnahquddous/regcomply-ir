---
export interface Props {
  title?: string;
}
const { title = "RegComply-IR — ADGM Regulatory Intelligence" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="ADGM Regulatory Compliance Intelligence — search, retrieve, and synthesize regulatory documents with AI." />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body>
    <!-- Background layers -->
    <div class="bg-grid" aria-hidden="true"></div>
    <div class="bg-glow" aria-hidden="true"></div>
    <div class="bg-noise" aria-hidden="true"></div>

    <slot />
  </body>
</html>